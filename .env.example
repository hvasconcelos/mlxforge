# mlxforge environment variables
#
# Copy to `.env` and adjust as needed. All variables are optional; the values
# shown are the built-in defaults. The server (`mlxforge`) reads every variable
# below; the CLI (`mlxforge-cli`) reads only the MLXFORGE_LOG_* ones.
#
# CLI flags override the server-config variables (e.g. `--port 9000` beats
# MLXFORGE_PORT). Nothing here is loaded automatically — export the vars in your
# shell, or source this file: `set -a; . ./.env; set +a`.

# --- Server ------------------------------------------------------------------

# Bind address for the HTTP server.
MLXFORGE_HOST=0.0.0.0

# Listen port.
MLXFORGE_PORT=8080

# Maximum prompt length (tokens); longer prompts are rejected with HTTP 400.
MLXFORGE_MAX_CTX=8192

# Bounded waiting queue; further requests get HTTP 429 once it is full.
MLXFORGE_MAX_WAITING=256

# KV-cache admission budget in bytes (0 = unbounded).
MLXFORGE_KV_BUDGET=0

# --- Logging -----------------------------------------------------------------

# Verbosity: trace | debug | info | warn | error | critical | off.
# An unrecognized value falls back to info.
MLXFORGE_LOG_LEVEL=info

# Optional log file. If set, logs are appended here in addition to the console
# (stderr). Leave unset/empty for console-only.
# MLXFORGE_LOG_FILE=/var/log/mlxforge.log

# spdlog message pattern. See https://github.com/gabime/spdlog/wiki/Custom-formatting
# MLXFORGE_LOG_PATTERN=[%H:%M:%S.%e] [%^%l%$] %v
